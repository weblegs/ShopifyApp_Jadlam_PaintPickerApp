// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ProductMeta {
  id              Int      @id @default(autoincrement())
  product_id      String
  product_title   String
  metafield_name  String
  metafield_value String
  colourgroup     String   @default("")
  shop            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([product_id, shop])
}

model HexCodeProduct {
  id          Int      @id @default(autoincrement())
  product_id  String
  hex_color   String
  group_name  String
  shop        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([product_id, shop])
}

model SearchProduct {
  id                  Int      @id @default(autoincrement())
  product_id          String
  product_title       String
  variant_id          String   @default("")
  sku                 String   @default("")
  price               String   @default("")
  compare_at_price    String   @default("")
  inventory_quantity  Int      @default(0)
  vendor              String   @default("")
  handle              String   @default("")
  paint_hexa_code     String   @default("")
  paint_colour        String   @default("")
  paint_type          String   @default("")
  paint_container     String   @default("")
  paint_number        String   @default("")
  paint_range         String   @default("")
  shop                String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([product_id, shop])
}
